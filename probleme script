    if ($IncludeExtensions.Count -gt 0) {
        foreach ($inc in $IncludeExtensions) {
            if ($inc -eq "" -and $file.Extension -eq "") { return $true }
            if ($inc -ne "" -and $file.Extension -eq $inc) { return $true }
        }
        return $false
    }
    return $true
}

