Param (
    [Parameter(Mandatory=$false)]
    [string]$RootPath,

    [string]$ReferencePath = "",

    [string[]]$ExcludePaths = @(),
    [string[]]$IncludeExtensions = @(),

    [int]$MaxLinesPerFile = 1000,

    [string]$Mode = "",

    [string]$OutputDir = "",

    [switch]$help
)

# Détermination dynamique du nom du script pour cohérence dans l'aide et les exemples
$ScriptName = Split-Path -Leaf $MyInvocation.MyCommand.Path

function Get-SafePath {
    param(
        [string]$BaseDir,
        [string]$RelPath
    )
    # Gère les chemins trop longs (Windows : 260 max, 248 pour les dossiers)
    $maxPath = 250
    $DestFile = Join-Path $BaseDir $RelPath
    if ($DestFile.Length -le $maxPath) { return $DestFile }
    $directory = Split-Path $DestFile -Parent
    $filename = Split-Path $DestFile -Leaf
    $ext = [System.IO.Path]::GetExtension($filename)
    $basename = [System.IO.Path]::GetFileNameWithoutExtension($filename)
    $maxBaseLen = $maxPath - $directory.Length - $ext.Length - 1
    if ($maxBaseLen -lt 6) { $maxBaseLen = 6 }
    if ($basename.Length -gt $maxBaseLen) {
        $shortName = $basename.Substring(0, [Math]::Min($basename.Length, $maxBaseLen - 5)) + "_..." + [System.Guid]::NewGuid().ToString("N").Substring(0,4)
    } else {
        $shortName = $basename
    }
    $safeFile = Join-Path $directory ($shortName + $ext)
    if ($safeFile.Length -gt $maxPath) {
        # Fallback : nom hashé
        $hashed = [System.BitConverter]::ToString([System.Security.Cryptography.SHA1]::Create().ComputeHash([System.Text.Encoding]::UTF8.GetBytes($RelPath))).Replace("-", "")
        $safeFile = Join-Path $directory ($hashed.Substring(0,16) + $ext)
    }
    return $safeFile
}

if ($help) {
    Write-Host @"
UTILISATION :
--------------
    .\$ScriptName -RootPath <Chemin> [options]

OPTIONS :
---------
    -RootPath <string>           Dossier à analyser (obligatoire sauf -help)
    -ReferencePath <string>      Dossier de référence pour la comparaison (optionnel)
    -ExcludePaths <array>        Chemins/motifs à exclure (ex : .git, *.log, C:\abs\path, "")
    -IncludeExtensions <array>   Extensions à inclure (ex : .txt, .ps1, ""). La chaîne vide "" permet de cibler les fichiers sans extension.
    -OutputDir <string>          Dossier où stocker les exports (défaut : sous RootPath\Output)
    -MaxLinesPerFile <int>       Lignes max par fichier texte exporté (extract sans reference)
    -Mode <string>               "open" pour ouvrir les fichiers trouvés (sinon extract par défaut)
    -help                        Affiche cette aide

GESTION DES FICHIERS SANS EXTENSION :
-------------------------------------
    - Pour inclure uniquement les fichiers sans extension :
        -IncludeExtensions ""
    - Pour inclure .txt et sans extension :
        -IncludeExtensions .txt,""
    - Pour exclure les fichiers sans extension :
        -ExcludePaths ""

COMPORTEMENT :
--------------
- Si -RootPath seul : extrait tout (export complet du dossier).
- Si -RootPath ET -ReferencePath : exporte uniquement les fichiers différents ou absents (différence de contenu, comparaison SHA256).
- Si -Mode open : ouvre dans des terminaux PowerShell les fichiers trouvés (diffs si ReferencePath, tout sinon).
- Sinon (par défaut) : mode extract, fichiers exportés dans OutputDir en conservant l'arborescence.

EXEMPLES :
----------
    # Export complet :
    .\$ScriptName -RootPath "C:\MonApp\Config"

    # Export uniquement des différences avec un dossier de référence :
    .\$ScriptName -RootPath "C:\ConfigModif" -ReferencePath "C:\ConfigDefaut"

    # Ouvrir uniquement les différences :
    .\$ScriptName -RootPath "C:\ConfigModif" -ReferencePath "C:\ConfigDefaut" -Mode open

    # Export avec filtrage pour .json et sans extension :
    .\$ScriptName -RootPath "C:\Config" -IncludeExtensions .json,"" -ExcludePaths .git

REMARQUES :
-----------
- Les exclusions/inclusions s’appliquent dans tous les cas.
- Structure de dossiers préservée lors de l’extract/export.
- L'utilisation de "" dans -IncludeExtensions ou -ExcludePaths cible explicitement les fichiers sans extension.
"@
    return
}

if (-not $RootPath) {
    Write-Error "Le paramètre -RootPath est obligatoire (voir -help)."
    return
}

function Test-Exclusion {
    param($File)
    foreach ($pattern in $ExcludePaths) {
        if ($pattern -eq "") {
            if ($File.Extension -eq "") { return $true }
        }
        elseif ($pattern -like "*`**") {
            if ($File.FullName -like $pattern) { return $true }
            if ($File.Name -like $pattern) { return $true }
        }
        elseif ($pattern.StartsWith(".")) {
            if ($File.Extension -eq $pattern) { return $true }
        }
        else {
            if ($File.FullName.StartsWith($pattern, [System.StringComparison]::InvariantCultureIgnoreCase)) {
                return $true
            }
        }
    }
    return $false
}

function Get-FileHashSHA256 {
    param($Path)
    try {
        if (Test-Path -Path $Path) {
            return (Get-FileHash -Algorithm SHA256 -Path $Path).Hash
        }
        return ""
    } catch {
        return ""
    }
}

# Construction du dossier de sortie
